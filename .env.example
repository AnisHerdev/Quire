# Quire — Required build-time environment variables
# Copy this file to .env, fill in your values, then run:
#   set -a; source .env; set +a; snapcraft --destructive-mode
#
# Get these from Firebase Console → Project Settings → General → Your apps
# and Google Cloud Console → APIs & Services → Credentials

FIREBASE_API_KEY_QUIRE=""
FIREBASE_APP_ID_QUIRE=""
FIREBASE_SENDER_ID_QUIRE=""
FIREBASE_PROJECT_ID_QUIRE=""
GOOGLE_OAUTH_CLIENT_ID_QUIRE=""
GOOGLE_OAUTH_CLIENT_SECRET_QUIRE=""
